# Copy to .env and fill in. Nothing here is secret — all open-source.
SERVICE_HOST=0.0.0.0
SERVICE_PORT=8000
DEVICE=auto                      # auto | cuda | cuda:0 | cpu
LOG_LEVEL=INFO
DEFAULT_LANGUAGE=en

# CosyVoice2 model source: modelscope (default) or huggingface
COSYVOICE_SOURCE=modelscope     # modelscope | huggingface
COSYVOICE_MODEL_ID=iic/CosyVoice2-0.5B

# HuggingFace mirror (for Colab where ModelScope may be slow)
HF_HUB_CACHE=./.cache/hf

# Whisper model for WER evaluation
ASR_MODEL=openai/whisper-medium

# Disable one backend entirely if it fails to install on your runtime
ENABLE_COSYVOICE2=true
ENABLE_CHATTERBOX=true
ENABLE_XTTS=true
ENABLE_MMSTS=true
